create database churn_ana;
use churn_ana;
CREATE TABLE customers (
    customerID VARCHAR(100),
    gender VARCHAR(100),
    SeniorCitizen INT,
    Partner VARCHAR(100),
    Dependents VARCHAR(100),
    tenure INT,
    PhoneService VARCHAR(100),
    MultipleLines VARCHAR(200),
    InternetService VARCHAR(200),
    OnlineSecurity VARCHAR(200),
    OnlineBackup VARCHAR(200),
    DeviceProtection VARCHAR(200),
    TechSupport VARCHAR(200),
    StreamingTV VARCHAR(200),
    StreamingMovies VARCHAR(200),
    Contract VARCHAR(200),
    PaperlessBilling VARCHAR(100),
    PaymentMethod VARCHAR(500),
    MonthlyCharges DECIMAL(10,2),
    TotalCharges VARCHAR(200),
    Churn VARCHAR(100)
);

select * from customers;

select customerID, count(*) as count
from customers
group by customerID
having count(*) >1;

select * from customers;

select distinct TotalCharges
from customers;

SELECT * FROM customers
WHERE TotalCharges = ' ';

UPDATE customers
SET TotalCharges = NULL
WHERE TotalCharges = ' ';

SET SQL_SAFE_UPDATES = 0;

ALTER TABLE customers
MODIFY TotalCharges DECIMAL(10,2);
DESCRIBE customers;

SELECT COUNT(*) AS total_customers FROM customers;

select distinct churn
from customers;

SELECT Churn, COUNT(*) AS total
FROM customers
GROUP BY Churn;	

SELECT 
ROUND(
    SUM(CASE WHEN Churn='Yes' THEN 1 ELSE 0 END)*100.0 / COUNT(*), 
2
) AS churn_rate
FROM customers;

SELECT 
Contract,
COUNT(*) AS total_customers,
SUM(CASE WHEN Churn='Yes' THEN 1 ELSE 0 END) AS churn_count
FROM customers
GROUP BY Contract;

SELECT 
COUNT(*) AS total_rows,
SUM(CASE WHEN TotalCharges IS NULL THEN 1 ELSE 0 END) AS null_totalcharges
FROM customers;
SELECT customerID, COUNT(*)
FROM customers
GROUP BY customerID
HAVING COUNT(*) > 1;
